# P2 Meridian — Analytics Pipeline Environment Variables
# Copy this file to .env and fill in values as needed

# Data Input/Output Paths
# INPUT_DATA_PATH=../fetch-immigration-data/downloads
# OUTPUT_ARTIFACTS_PATH=./artifacts
# (defaults: shown above)

# Model Training
# ML_MODEL_PATH=./models
# USE_GPU=false
# RANDOM_SEED=42

# Data Processing
# DATE_LOOKBACK_MONTHS=36
# (default: 36 for 3-year rolling window)
# MIN_SAMPLE_SIZE=10
# (minimum cases required for statistics)

# Logging & Debug
# LOG_LEVEL=INFO
# DEBUG_MODE=false
# VERBOSE_OUTPUT=true
# (options: DEBUG, INFO, WARNING, ERROR)

# Parallel Processing
# NUM_WORKERS=4
# (defaults to CPU count)

# Optional: External Data Sources
# CENSUS_API_KEY=your_key_here
# BLS_API_KEY=your_key_here

# Artifact Export
# EXPORT_FORMAT=parquet,json
# COMPRESS_JSON=true
# (compress large JSON files for storage)
